APP_NAME=Lumen
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
APP_TIMEZONE=UTC

LOG_CHANNEL=stack
LOG_SLACK_WEBHOOK_URL=

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=homestead
DB_USERNAME=homestead
DB_PASSWORD=secret

CACHE_DRIVER=file
QUEUE_CONNECTION=sync

# JWT Configuration
JWT_SECRET=potash_copper_coal
JWT_EXPIRATION_MINUTES=30

# CORS Configuration
# Use * for all origins (development)
# Use comma-separated URLs for specific origins (production)
# Examples:
# CORS_ALLOWED_ORIGINS=*
# CORS_ALLOWED_ORIGINS=http://localhost:3000
# CORS_ALLOWED_ORIGINS=http://localhost:3000,https://app.example.com,http://54.123.45.67
CORS_ALLOWED_ORIGINS=*

# EDA Configuration
EDA_FILES_PATH=/data/eda_files/FILES
DUCKDB_PATH=/usr/local/bin/duckdb

# DuckDB Performance Settings
# Adjust based on instance size:
# t4g.small (2GB RAM): DUCKDB_MEMORY=1GB, DUCKDB_VCPU=2, EDA_DATA_LIMIT=1000
# t4g.medium (4GB RAM): DUCKDB_MEMORY=3GB, DUCKDB_VCPU=2, EDA_DATA_LIMIT=5000
# t4g.large (8GB RAM): DUCKDB_MEMORY=6GB, DUCKDB_VCPU=2, EDA_DATA_LIMIT=10000
DUCKDB_MEMORY=3GB
DUCKDB_VCPU=2
EDA_DATA_LIMIT=5000
